spring.datasource.url=jdbc:postgresql://localhost:5432/GainZone
spring.datasource.username=postgres
spring.datasource.password=${DB_PASSWORD:votre_mot_de_passe}
spring.datasource.driver-class-name=org.postgresql.Driver
application.jwt.secret=${JWT_SECRET:votre_cle_secrete_très_longue_générique}
server.port=8081

# Hibernate properties
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# Configuration Ollama pour l'analyse morphologique
spring.ai.ollama.base-url=http://localhost:11434
spring.ai.ollama.chat.options.model=llava
spring.ai.ollama.chat.options.timeout=60s

# Niveaux de logs Propres
logging.level.org.springframework=ERROR
logging.level.org.hibernate=ERROR
logging.level.org.example.gainzone=INFO
